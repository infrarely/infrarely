# InfraRely .gitignore — Production-grade

# ═══════════════════════════════════════════════════════════════════════════════
# Python
# ═══════════════════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
sdist/
wheels/
*.whl

# ═══════════════════════════════════════════════════════════════════════════════
# Virtual environments
# ═══════════════════════════════════════════════════════════════════════════════
.venv/
venv/
ENV/
env/
.env
.env.*
!.env.example

# ═══════════════════════════════════════════════════════════════════════════════
# IDE / Editor
# ═══════════════════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ═══════════════════════════════════════════════════════════════════════════════
# Testing
# ═══════════════════════════════════════════════════════════════════════════════
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ═══════════════════════════════════════════════════════════════════════════════
# Type checking
# ═══════════════════════════════════════════════════════════════════════════════
.mypy_cache/
.pytype/

# ═══════════════════════════════════════════════════════════════════════════════
# Logs & Runtime artifacts
# ═══════════════════════════════════════════════════════════════════════════════
logs/
*.log
*.db
*.sqlite
*.sqlite3

# ═══════════════════════════════════════════════════════════════════════════════
# InfraRely runtime artifacts
# ═══════════════════════════════════════════════════════════════════════════════
.infrarely_versions/
.infrarely_packages/
.aos_versions/
.aos_packages/

# ═══════════════════════════════════════════════════════════════════════════════
# Trash — old project files (pre-migration)
# ═══════════════════════════════════════════════════════════════════════════════
trash/
